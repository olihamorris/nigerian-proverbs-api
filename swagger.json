{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs API",
    "version": "1.0.0",
    "description": "API for Nigerian proverbs and tribes"
  },
  "servers": [
    {
      "url": "https://nigerian-proverbs-api.onrender.com"
    }
  ],
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Get all proverbs",
        "responses": {
          "200": {
            "description": "List of proverbs"
          }
        }
      },
      "post": {
        "summary": "Create a proverb",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "proverb": "When the moon is shining the cripple becomes hungry for a walk",
                "meaning": "Good opportunities encourage people to act",
                "tribe": "Igbo",
                "provider": "Morris",
                "date": "2026",
                "language": "Igbo",
                "category": "Opportunity"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },

    "/tribes": {
      "get": {
        "summary": "Get all tribes",
        "responses": {
          "200": {
            "description": "List of tribes"
          }
        }
      },
      "post": {
        "summary": "Create a tribe",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "tribe": "Yoruba",
                "region": "South West",
                "language": "Yoruba",
                "population": "40 million",
                "famousProverb": "What a child says he has heard at home",
                "provider": "Morris",
                "date": "2026"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    }
  }
}