{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs and Tribes API",
    "description": "API for managing Nigerian proverbs and tribes information.",
    "version": "1.0.0"
  },
  "servers": [
    {
    "url": "https://nigerian-proverbs-api.onrender.com"
  }
  ],
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Get all proverbs",
        "responses": {
          "200": {
            "description": "List of proverbs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Proverb"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a proverb",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Proverb"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Proverb created"
          }
        }
      }
    },
    "/proverbs/{id}": {
      "get": {
        "summary": "Get proverb by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Proverb found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Proverb"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Proverb"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Proverb updated"
          }
        }
      },
      "delete": {
        "summary": "Delete proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Proverb deleted"
          }
        }
      }
    },

    "/tribes": {
      "get": {
        "summary": "Get all tribes",
        "responses": {
          "200": {
            "description": "List of tribes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tribe"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a tribe",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tribe"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tribe created"
          }
        }
      }
    },

    "/tribes/{id}": {
      "get": {
        "summary": "Get tribe by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tribe found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Tribe"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tribe"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Tribe updated"
          }
        }
      },
      "delete": {
        "summary": "Delete tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tribe deleted"
          }
        }
      }
    }
  },

  "components": {
    "schemas": {

      "Proverb": {
        "type": "object",
        "required": [
          "tribe",
          "proverb",
          "meaning",
          "literalTranslation",
          "usageContext",
          "provider",
          "date"
        ],
        "properties": {
          "tribe": {
            "type": "string"
          },
          "proverb": {
            "type": "string"
          },
          "meaning": {
            "type": "string"
          },
          "literalTranslation": {
            "type": "string"
          },
          "usageContext": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "date": {
            "type": "string"
          }
        }
      },

      "Tribe": {
        "type": "object",
        "required": [
          "name",
          "region",
          "language",
          "population",
          "culture",
          "provider",
          "date"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "population": {
            "type": "string"
          },
          "culture": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "date": {
            "type": "string"
          }
        }
      }

    }
  }
}