{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs API",
    "version": "1.0.0",
    "description": "API for Nigerian proverbs and tribes"
  },
  "servers": [
    {
      "url": "https://nigerian-proverbs-api.onrender.com"
    }
  ],
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Get all proverbs",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "post": {
        "summary": "Create a proverb",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Proverb"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Proverb created"
          }
        }
      }
    },
    "/proverbs/{id}": {
      "get": {
        "summary": "Get one proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "put": {
        "summary": "Update a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Proverb"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted successfully"
          }
        }
      }
    },
    "/tribes": {
      "get": {
        "summary": "Get all tribes",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "post": {
        "summary": "Create a tribe",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tribe"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tribe created"
          }
        }
      }
    },
    "/tribes/{id}": {
      "get": {
        "summary": "Get one tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      },
      "put": {
        "summary": "Update a tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tribe"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete a tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted successfully"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Proverb": {
        "type": "object",
        "properties": {
          "proverb": {
            "type": "string"
          },
          "meaning": {
            "type": "string"
          },
          "tribe": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      },
      "Tribe": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "population": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "culture": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}