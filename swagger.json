{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs API",
    "version": "1.0.0",
    "description": "An API that provides Nigerian proverbs and tribes information"
  },
  "servers": [
    {
      "url": "https://nigerian-proverbs-api.onrender.com"
    }
  ],
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Retrieve all Nigerian proverbs",
        "responses": {
          "200": {
            "description": "A list of proverbs"
          }
        }
      },
      "post": {
        "summary": "Create a new proverb",
        "requestBody": {
          "$ref": "#/components/requestBodies/ProverbBody"
        },
        "responses": {
          "201": {
            "description": "Proverb successfully created"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },

    "/proverbs/{id}": {
      "get": {
        "summary": "Retrieve a single proverb by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single proverb"
          }
        }
      },

      "put": {
        "summary": "Update a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/ProverbBody"
        },
        "responses": {
          "200": {
            "description": "Proverb updated"
          }
        }
      },

      "delete": {
        "summary": "Delete a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Proverb deleted"
          }
        }
      }
    },

    "/tribes": {
      "get": {
        "summary": "Retrieve all Nigerian tribes",
        "responses": {
          "200": {
            "description": "A list of tribes"
          }
        }
      },
      "post": {
        "summary": "Create a new tribe",
        "requestBody": {
          "$ref": "#/components/requestBodies/TribeBody"
        },
        "responses": {
          "201": {
            "description": "Tribe successfully created"
          }
        }
      }
    },

    "/tribes/{id}": {
      "get": {
        "summary": "Retrieve a single tribe by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single tribe"
          }
        }
      },

      "put": {
        "summary": "Update a tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/TribeBody"
        },
        "responses": {
          "200": {
            "description": "Tribe updated"
          }
        }
      },

      "delete": {
        "summary": "Delete a tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Tribe deleted"
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "Proverb": {
        "type": "object",
        "properties": {
          "proverb": { "type": "string" },
          "meaning": { "type": "string" },
          "tribe": { "type": "string" },
          "provider": { "type": "string" },
          "date": { "type": "string" },
          "language": { "type": "string" },
          "category": { "type": "string" }
        }
      },

      "Tribe": {
        "type": "object",
        "properties": {
          "tribe": { "type": "string" },
          "region": { "type": "string" },
          "language": { "type": "string" },
          "population": { "type": "string" },
          "famousProverb": { "type": "string" },
          "provider": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    },

    "requestBodies": {
      "ProverbBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Proverb"
            }
          }
        }
      },

      "TribeBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Tribe"
            }
          }
        }
      }
    }
  }
}