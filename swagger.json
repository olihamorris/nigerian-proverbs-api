{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs API",
    "version": "1.0.0",
    "description": "An API that provides Nigerian proverbs and tribes information"
  },
  "servers": [
    {
      "url": "https://nigerian-proverbs-api.onrender.com"
    }
  ],
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Retrieve all Nigerian proverbs",
        "responses": {
          "200": {
            "description": "A list of proverbs"
          }
        }
      },
      "post": {
        "summary": "Create a new proverb",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "proverb": "What a child says he has heard at home",
                "meaning": "Children reflect what they hear in their homes",
                "tribe": "Yoruba",
                "provider": "Morris",
                "date": "2026",
                "language": "Yoruba",
                "category": "Family"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Proverb successfully created"
          }
        }
      }
    },

    "/proverbs/{id}": {
      "get": {
        "summary": "Retrieve a single proverb by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single proverb"
          }
        }
      },

      "put": {
        "summary": "Update a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "proverb": "Updated proverb",
                "meaning": "Updated meaning",
                "tribe": "Igbo",
                "provider": "Morris",
                "date": "2026",
                "language": "Igbo",
                "category": "Wisdom"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Proverb updated"
          }
        }
      },

      "delete": {
        "summary": "Delete a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Proverb deleted"
          }
        }
      }
    },

    "/tribes": {
      "get": {
        "summary": "Retrieve all Nigerian tribes",
        "responses": {
          "200": {
            "description": "A list of tribes"
          }
        }
      },
      "post": {
        "summary": "Create a new tribe",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "tribe": "Yoruba",
                "region": "South West Nigeria",
                "language": "Yoruba",
                "population": "Over 40 million",
                "famousProverb": "What a child says he has heard at home",
                "provider": "Morris",
                "date": "2026"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tribe successfully created"
          }
        }
      }
    }
  }
}