{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs API",
    "description": "An API that provides Nigerian proverbs and tribes information",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://nigerian-proverbs-api.onrender.com"
    }
  ],
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Retrieve all Nigerian proverbs",
        "responses": {
          "200": {
            "description": "A list of proverbs"
          }
        }
      },
      "post": {
        "summary": "Create a new proverb",
        "responses": {
          "201": {
            "description": "Proverb successfully created"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },

    "/proverbs/{id}": {
      "get": {
        "summary": "Retrieve a single proverb by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID of the proverb",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single proverb"
          }
        }
      },

      "put": {
        "summary": "Update a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Proverb updated"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      },

      "delete": {
        "summary": "Delete a proverb",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Proverb deleted"
          }
        }
      }
    },

    "/tribes": {
      "get": {
        "summary": "Retrieve all Nigerian tribes",
        "responses": {
          "200": {
            "description": "A list of tribes"
          }
        }
      },
      "post": {
        "summary": "Create a new tribe",
        "responses": {
          "201": {
            "description": "Tribe successfully created"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },

    "/tribes/{id}": {
      "get": {
        "summary": "Retrieve a single tribe by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A single tribe"
          }
        }
      },

      "put": {
        "summary": "Update a tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tribe updated"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      },

      "delete": {
        "summary": "Delete a tribe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Tribe deleted"
          }
        }
      }
    }
  }
}