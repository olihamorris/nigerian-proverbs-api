{
  "openapi": "3.0.0",
  "info": {
    "title": "Nigerian Proverbs and Tribes API",
    "description": "API for managing Nigerian proverbs and tribes with OAuth authentication.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://nigerian-proverbs-api.onrender.com"
    }
  ],
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
            "tokenUrl": "https://oauth2.googleapis.com/token",
            "scopes": {
              "profile": "Access user profile"
            }
          }
        }
      }
    },
    "schemas": {
      "Proverb": {
        "type": "object",
        "required": [
          "tribe",
          "proverb",
          "meaning",
          "provider",
          "date"
        ],
        "properties": {
          "tribe": { "type": "string" },
          "proverb": { "type": "string" },
          "meaning": { "type": "string" },
          "literalTranslation": { "type": "string" },
          "usageContext": { "type": "string" },
          "provider": { "type": "string" },
          "date": { "type": "string" }
        }
      },
      "Tribe": {
        "type": "object",
        "required": [
          "name",
          "region",
          "language",
          "provider",
          "date"
        ],
        "properties": {
          "name": { "type": "string" },
          "region": { "type": "string" },
          "language": { "type": "string" },
          "population": { "type": "string" },
          "culture": { "type": "string" },
          "provider": { "type": "string" },
          "date": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/proverbs": {
      "get": {
        "summary": "Get all proverbs",
        "responses": {
          "200": {
            "description": "List of proverbs"
          }
        }
      },
      "post": {
        "summary": "Create a proverb (Protected)",
        "security": [{ "oauth2": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Proverb"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/proverbs/{id}": {
      "get": {
        "summary": "Get proverb by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Found" }
        }
      },
      "put": {
        "summary": "Update proverb (Protected)",
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Proverb"
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Updated" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "summary": "Delete proverb (Protected)",
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/tribes": {
      "get": {
        "summary": "Get all tribes",
        "responses": {
          "200": {
            "description": "List of tribes"
          }
        }
      },
      "post": {
        "summary": "Create a tribe (Protected)",
        "security": [{ "oauth2": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Tribe"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/tribes/{id}": {
      "get": {
        "summary": "Get tribe by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Found" }
        }
      },
      "put": {
        "summary": "Update tribe (Protected)",
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Updated" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "summary": "Delete tribe (Protected)",
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  }
}